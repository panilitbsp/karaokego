<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <ImageView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_settings" app:tint="#FFFFFF"
        android:contentDescription="Pengaturan Efek Suara"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 1. Gambar Mic ditaruh paling atas agar ID-nya dibaca duluan oleh sistem -->
    <ImageView
        android:id="@+id/ivMic"
        android:layout_width="250dp"
        android:layout_height="450dp"
        android:scaleType="fitCenter"
        android:src="@drawable/mic_image"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Tombol untuk menyalakan dan mematikan mikrofon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. Teks Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MIC OFF"
        android:textColor="#555555"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@+id/ivMic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 3. Petunjuk UI -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap gambar mic untuk On/Off"
        android:textColor="#444444"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@+id/ivMic"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>